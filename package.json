{
  "name": "college-test-system",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "description": "Колледж онлайн тест жүйесі",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev:server": "node server/app.js",
    "dev:client": "npm --prefix client run dev",
    "dev": "npm run dev:server",
    "dev:full": "node scripts/dev.js",
    "build:client": "npm --prefix client run build",
    "build": "npm run build:client && rm -rf dist && mv client/dist dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  }
}
